{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "VMs Provisioned / Deprovisioned",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(truenas_vms_provisioned_total[5m])", "legendFormat": "Provisioned" },
        { "expr": "rate(truenas_vms_deprovisioned_total[5m])", "legendFormat": "Deprovisioned" },
        { "expr": "rate(truenas_vms_errored_total[5m])", "legendFormat": "Errors" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Running VMs",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 0 },
      "targets": [
        { "expr": "truenas_host_vms_running", "legendFormat": "VMs" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Host CPU Cores",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 0 },
      "targets": [
        { "expr": "truenas_host_cpu_cores", "legendFormat": "Cores" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Host Memory",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 0 },
      "targets": [
        { "expr": "truenas_host_memory_total_bytes / 1024 / 1024 / 1024", "legendFormat": "GiB" }
      ],
      "fieldConfig": { "defaults": { "unit": "decgbytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Pool Free Space",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "truenas_host_pool_free_bytes", "legendFormat": "{{ pool }} free" }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Pool Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "truenas_host_pool_healthy", "legendFormat": "{{ pool }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Disks",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "truenas_host_disks_total", "legendFormat": "Total" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "API Call Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(truenas_api_duration_seconds_bucket[5m]))", "legendFormat": "p99" },
        { "expr": "histogram_quantile(0.50, rate(truenas_api_duration_seconds_bucket[5m]))", "legendFormat": "p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Provision Duration (p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(truenas_provision_duration_seconds_bucket[5m]))", "legendFormat": "Provision p99" },
        { "expr": "histogram_quantile(0.99, rate(truenas_deprovision_duration_seconds_bucket[5m]))", "legendFormat": "Deprovision p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Zvol Resizes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "targets": [
        { "expr": "truenas_zvols_resized_total", "legendFormat": "Resized" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Snapshots Created",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "targets": [
        { "expr": "truenas_snapshots_created_total", "legendFormat": "Created" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Rate Limited Calls",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "targets": [
        { "expr": "rate(truenas_api_duration_seconds_count[1m])", "legendFormat": "API calls/sec" }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["truenas", "omni", "kubernetes"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "TrueNAS Omni Provider",
  "uid": "truenas-omni-provider"
}
