{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    },
    {
      "name": "DS_PYROSCOPE",
      "label": "Pyroscope",
      "description": "",
      "type": "datasource",
      "pluginId": "grafana-pyroscope-datasource",
      "pluginName": "Grafana Pyroscope"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "tempo",
      "name": "Tempo",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-pyroscope-datasource",
      "name": "Grafana Pyroscope",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "TrueNAS JSON-RPC API call performance, rate limiting, WebSocket health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Overview",
      "url": "/d/truenas-overview",
      "type": "link"
    },
    {
      "title": "Provisioning",
      "url": "/d/truenas-provisioning",
      "type": "link"
    },
    {
      "title": "Cleanup & Maintenance",
      "url": "/d/truenas-cleanup",
      "type": "link"
    }
  ],
  "panels": [
    {
      "title": "API Latency",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "API Call Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(truenas_api_duration_seconds_bucket{job=~\"$job\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(truenas_api_duration_seconds_bucket{job=~\"$job\"}[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(truenas_api_duration_seconds_bucket{job=~\"$job\"}[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "API Call Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(rate(truenas_api_duration_seconds_count{job=~\"$job\"}[5m]))",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "WS Reconnects",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "expr": "truenas_ws_reconnects_total{job=~\"$job\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Health Check Errors",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 5
      },
      "targets": [
        {
          "expr": "rate(truenas_healthcheck_errors_total{job=~\"$job\"}[5m])",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Rate Limit Queue",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 5
      },
      "targets": [
        {
          "expr": "truenas_ratelimit_queue_size{job=~\"$job\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 6
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Per-Method Breakdown",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false
    },
    {
      "title": "API Call Duration by Method (p95)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(truenas_api_duration_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "{{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 5,
            "lineWidth": 1
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "API Call Rate by Method",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "expr": "sum by (method) (rate(truenas_api_duration_seconds_count{job=~\"$job\"}[5m]))",
          "legendFormat": "{{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Slowest API Methods (avg, last 5m)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "targets": [
        {
          "expr": "topk(10, sum by (method) (rate(truenas_api_duration_seconds_sum{job=~\"$job\"}[5m])) / sum by (method) (rate(truenas_api_duration_seconds_count{job=~\"$job\"}[5m])))",
          "legendFormat": "{{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "continuous-BlYlRd"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Connection Health",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "collapsed": false
    },
    {
      "title": "Rate Limit Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "truenas_ratelimit_queue_size{job=~\"$job\"}",
          "legendFormat": "Queue depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20
          },
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "WebSocket Reconnects Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "targets": [
        {
          "expr": "rate(truenas_ws_reconnects_total{job=~\"$job\"}[5m])",
          "legendFormat": "Reconnects/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      }
    },
    {
      "title": "Traces & Logs",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "collapsed": false
    },
    {
      "title": "Slowest API Traces (> 1s)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "${DS_TEMPO}"
          },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "value": [
                "omni-infra-provider-truenas"
              ],
              "scope": "resource"
            },
            {
              "id": "span-name",
              "tag": "name",
              "operator": "=~",
              "value": [
                "truenas.*"
              ],
              "scope": "span"
            },
            {
              "id": "min-duration",
              "tag": "duration",
              "operator": ">",
              "value": [
                "1s"
              ],
              "scope": "intrinsic"
            }
          ],
          "limit": 20
        }
      ],
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      }
    },
    {
      "title": "API Error Logs",
      "type": "logs",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "expr": "{service_name=\"omni-infra-provider-truenas\"} | json | level=\"error\" or msg=~\".*failed.*\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none"
      },
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      }
    },
    {
      "title": "Profiling",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 42
      },
      "collapsed": false
    },
    {
      "title": "Goroutine Profile",
      "type": "flamegraph",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "profileTypeId": "goroutine:goroutine:count:goroutine:count",
          "labelSelector": "{service_name=\"omni-infra-provider-truenas\"}",
          "queryType": "profile",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "${DS_PYROSCOPE}"
      }
    },
    {
      "title": "Mutex Contention Profile",
      "type": "flamegraph",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "targets": [
        {
          "profileTypeId": "mutex:contentions:count:contentions:count",
          "labelSelector": "{service_name=\"omni-infra-provider-truenas\"}",
          "queryType": "profile",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "grafana-pyroscope-datasource",
        "uid": "${DS_PYROSCOPE}"
      }
    }
  ],
  "refresh": "30s",
  "tags": [
    "truenas",
    "omni",
    "api"
  ],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(truenas_api_duration_seconds_count, job)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Omni TrueNAS Provider \u2014 TrueNAS API Performance",
  "uid": "truenas-api",
  "id": null,
  "gnetId": null,
  "schemaVersion": 41,
  "version": 1,
  "timezone": "",
  "timepicker": {},
  "weekStart": ""
}
