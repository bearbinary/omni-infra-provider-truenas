{
  "annotations": { "list": [] },
  "description": "High-level health and status of the TrueNAS Omni infrastructure provider",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Provisioning", "url": "/d/truenas-provisioning", "type": "link" },
    { "title": "API Performance", "url": "/d/truenas-api", "type": "link" },
    { "title": "Cleanup & Maintenance", "url": "/d/truenas-cleanup", "type": "link" }
  ],
  "panels": [
    {
      "title": "Provider Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Running VMs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "targets": [
        { "expr": "truenas_host_vms_running{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "VMs Provisioned",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "targets": [
        { "expr": "truenas_vms_provisioned_total{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "VM Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "targets": [
        { "expr": "truenas_vms_errored_total{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Health Check Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "targets": [
        { "expr": "truenas_healthcheck_errors_total{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "CPU Cores",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "targets": [
        { "expr": "truenas_host_cpu_cores{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Host Memory",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "targets": [
        { "expr": "truenas_host_memory_total_bytes{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Total Disks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "targets": [
        { "expr": "truenas_host_disks_total{job=~\"$job\"}", "legendFormat": "" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Provider Version",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "targets": [
        { "expr": "count(truenas_host_cpu_cores{job=~\"$job\", service_version=~\"$version\"}) or vector(0)", "legendFormat": "$version" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "noValue": "$version"
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "name" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Pool Health",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "Pool Health",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "targets": [
        { "expr": "truenas_host_pool_healthy{job=~\"$job\"}", "legendFormat": "{{ pool }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DEGRADED", "color": "red" }, "1": { "text": "HEALTHY", "color": "green" } } }
          ]
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto", "orientation": "horizontal" },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Pool Usage",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 10, "x": 6, "y": 6 },
      "targets": [
        { "expr": "truenas_host_pool_used_bytes{job=~\"$job\"} / (truenas_host_pool_free_bytes{job=~\"$job\"} + truenas_host_pool_used_bytes{job=~\"$job\"}) * 100", "legendFormat": "{{ pool }}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "orange", "value": 80 }, { "color": "red", "value": 90 }] }
        }
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Pool Free Space",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "targets": [
        { "expr": "truenas_host_pool_free_bytes{job=~\"$job\"}", "legendFormat": "{{ pool }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "VM Activity",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "collapsed": false
    },
    {
      "title": "VM Provisioning Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "rate(truenas_vms_provisioned_total{job=~\"$job\"}[5m])", "legendFormat": "Provisioned/s" },
        { "expr": "rate(truenas_vms_deprovisioned_total{job=~\"$job\"}[5m])", "legendFormat": "Deprovisioned/s" },
        { "expr": "rate(truenas_vms_errored_total{job=~\"$job\"}[5m])", "legendFormat": "Errors/s" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Errors/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Running VMs Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "expr": "truenas_host_vms_running{job=~\"$job\"}", "legendFormat": "Running VMs" }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "custom": { "fillOpacity": 20 } } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "title": "Logs & Profiles",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "title": "Recent Provider Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 22 },
      "targets": [
        { "expr": "{service_name=\"omni-infra-provider-truenas\"} | json", "refId": "A" }
      ],
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "enableLogDetails": true, "dedupStrategy": "none" },
      "datasource": { "type": "loki", "uid": "loki" }
    },
    {
      "title": "CPU Profile",
      "type": "flamegraph",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "profileTypeId": "process_cpu:cpu:nanoseconds:cpu:nanoseconds",
          "labelSelector": "{service_name=\"omni-infra-provider-truenas\"}",
          "queryType": "profile",
          "refId": "A"
        }
      ],
      "datasource": { "type": "grafana-pyroscope-datasource", "uid": "pyroscope" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["truenas", "omni", "overview"],
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(truenas_host_vms_running, job)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "version",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(truenas_host_cpu_cores, service_version)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "title": "TrueNAS Provider / Overview",
  "uid": "truenas-overview"
}
