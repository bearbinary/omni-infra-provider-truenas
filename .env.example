# Omni TrueNAS Provider — Environment Configuration
# Copy to .env and fill in your values.
# The provider loads this file automatically on startup.
#
# IMPORTANT: This provider requires TrueNAS SCALE 25.04+ (JSON-RPC 2.0 API).
# The legacy REST v2.0 API is NOT supported.

# --- Required: Omni Connection ---
OMNI_ENDPOINT=https://omni.example.com
OMNI_SERVICE_ACCOUNT_KEY=
OMNI_INSECURE_SKIP_VERIFY=false

# --- TrueNAS Connection ---
# Transport is auto-detected:
#   1. Unix socket (if mounted at /var/run/middleware/) — no API key needed
#   2. WebSocket — requires TRUENAS_HOST + TRUENAS_API_KEY
#
# When running as a TrueNAS app, the socket is mounted automatically.
# Only set these for remote deployments:
TRUENAS_HOST=
TRUENAS_API_KEY=
# Set to true only if TrueNAS uses a self-signed certificate.
# WARNING: Disabling TLS verification allows MITM attacks — avoid in production.
TRUENAS_INSECURE_SKIP_VERIFY=false
# TRUENAS_SOCKET_PATH=  # Override default: /var/run/middleware/middlewared.sock

# --- Provider Identity ---
PROVIDER_ID=truenas
PROVIDER_NAME=TrueNAS
PROVIDER_DESCRIPTION=TrueNAS SCALE infrastructure provider

# --- VM Defaults ---
DEFAULT_POOL=default
# Network interface for VM NICs — bridge (br100), VLAN (vlan666), or physical (enp5s0)
DEFAULT_NETWORK_INTERFACE=
DEFAULT_BOOT_METHOD=UEFI

# --- Advanced ---
CONCURRENCY=4
LOG_LEVEL=info
# TRUENAS_MAX_CONCURRENT_CALLS=8  # Max concurrent API calls to TrueNAS (prevents overload)
# ENCRYPTION_PASSPHRASE=           # Passphrase for ZFS encrypted zvols (required when encrypted=true in MachineClass)

# --- Observability (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_SERVICE_NAME=omni-infra-provider-truenas
# PYROSCOPE_URL=http://localhost:4040
