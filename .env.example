# Omni TrueNAS Provider — Environment Configuration
# Copy to .env and fill in your values.
# The provider loads this file automatically on startup.
#
# IMPORTANT: This provider requires TrueNAS SCALE 25.04+ (JSON-RPC 2.0 API).
# The legacy REST v2.0 API is NOT supported.

# --- Required: Omni Connection ---
OMNI_ENDPOINT=https://omni.example.com
OMNI_SERVICE_ACCOUNT_KEY=
OMNI_INSECURE_SKIP_VERIFY=false

# --- Required: TrueNAS Connection ---
# TrueNAS 25.10 removed implicit authentication on the Unix socket, so API key
# authentication is required regardless of where the provider runs.
# Create an API key for a dedicated non-root user with scoped roles.
# See docs/truenas-setup.md#5-api-key for the recommended role set.
# Do NOT use the root user's API key.
TRUENAS_HOST=
TRUENAS_API_KEY=
# Set to true only if TrueNAS uses a self-signed certificate.
# WARNING: Disabling TLS verification allows MITM attacks — avoid in production.
TRUENAS_INSECURE_SKIP_VERIFY=false

# --- Provider Identity ---
PROVIDER_ID=truenas
PROVIDER_NAME=TrueNAS
PROVIDER_DESCRIPTION=TrueNAS SCALE infrastructure provider

# --- VM Defaults ---
DEFAULT_POOL=default
# Network interface for VM NICs — bridge (br100), VLAN (vlan666), or physical (enp5s0)
DEFAULT_NETWORK_INTERFACE=
DEFAULT_BOOT_METHOD=UEFI

# --- Advanced ---
CONCURRENCY=4
LOG_LEVEL=info
# TRUENAS_MAX_CONCURRENT_CALLS=8  # Max concurrent API calls to TrueNAS (prevents overload)
# GRACEFUL_SHUTDOWN_TIMEOUT=30     # Seconds to wait for ACPI shutdown before force-stop (default: 30)
# MAX_ERROR_RECOVERIES=5           # Max consecutive ERROR recoveries before auto-replacing a VM (-1 to disable)
# HEALTH_LISTEN_ADDR=:8081         # HTTP health endpoint address (/healthz, /readyz)

# --- Singleton Enforcement ---
# Prevents two instances with the same PROVIDER_ID from racing on provisioning.
# Disable only for debugging or advanced sharding setups.
# PROVIDER_SINGLETON_ENABLED=true           # Default: true
# PROVIDER_SINGLETON_REFRESH_INTERVAL=15s   # Heartbeat refresh cadence (default: 15s)
# PROVIDER_SINGLETON_STALE_AFTER=45s        # Age at which a heartbeat is considered dead (default: 45s, must be >= 2x refresh)

# --- Observability (optional) ---
# Local dev stack:
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
# OTEL_EXPORTER_OTLP_INSECURE=true
# OTEL_SERVICE_NAME=omni-infra-provider-truenas
# PYROSCOPE_URL=http://localhost:4040
#
# Grafana Cloud:
# OTEL_EXPORTER_OTLP_ENDPOINT=otlp-gateway-prod-us-east-0.grafana.net:443
# OTEL_EXPORTER_OTLP_INSECURE=false
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(instance_id:api_token)>
# OTEL_SERVICE_NAME=omni-infra-provider-truenas
# PYROSCOPE_URL=https://profiles-prod-028.grafana.net
# PYROSCOPE_BASIC_AUTH_USER=1551640
# PYROSCOPE_BASIC_AUTH_PASSWORD=<your-grafana-cloud-api-token>
#
# OTEL_CONSOLE_EXPORT=true   # Also emit telemetry to stdout (verbose, opt-in for local debugging)
