# Integration Test Environment
# Copy to .env.test and fill in your values.
# Loaded automatically by integration tests.
#
# Option 1: Unix socket (if running on TrueNAS host)
# TRUENAS_TEST_SOCKET=/var/run/middleware/middlewared.sock
#
# Option 2: WebSocket (remote)
TRUENAS_TEST_HOST=192.168.1.100
TRUENAS_TEST_API_KEY=your-truenas-api-key-here

TRUENAS_TEST_POOL=default
TRUENAS_TEST_NIC_ATTACH=br100
